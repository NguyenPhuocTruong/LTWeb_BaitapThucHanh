<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="index.css">
    <link rel="stylesheet" href="thong_tin_ca_nhan.css">
    <title>Thông tin cá nhân</title>
</head>
<body>
    <h1>Thông tin cá nhân</h1><br>
    <div>
        <div class="info_block"><h3 class="label">Họ tên </h3><p class="value"><%= name %></p></div>
        <div class="info_block"><h3 class="label">Email </h3><p class="value"><%= email %></p></div>
        <div class="info_block"><h3 class="label">Năm sinh </h3><p class="value"><%= birth %></p></div>
        <div class="info_block"><h3 class="label">Giới tính </h3><p class="value"><%= gender %></p></div>
    </div>
</body>
</html>